{
  "name": "novnc-cef-client",
  "version": "1.0.0",
  "description": "CEF-based NoVNC client with auto-connect and GPU acceleration",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "build:mac": "electron-builder --mac --publish never"
  },
  "build": {
    "appId": "com.hogan.novncclient",
    "productName": "NoVNC Client",
    "asar": true,
    "asarUnpack": [
      "node_modules/koffi/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "keywords": [],
  "author": "Hogan Hong",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "iconv-lite": "^0.7.2",
    "koffi": "^2.16.1"
  }
}
